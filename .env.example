# ============================================================
# .env.example — Copy to .env and fill in your values
# ============================================================
# NEVER commit .env to git. This file is safe to commit.

# ── Turso DB1 (identity, screener, forensic, ohlcv, alerts) ──
TURSO_DATABASE_URL=libsql://YOUR-DB-NAME.aws-ap-south-1.turso.io
TURSO_TOKEN=your_turso_db1_token_here

# ── Turso DB2 (signals, tickers, memories, concall, news) ────
TURSO_DATABASE_URL2=libsql://YOUR-DB2-NAME.aws-ap-south-1.turso.io
TURSO_TOKEN2=your_turso_db2_token_here

# ── RunPod (FinBERT sentiment scoring for news pipeline) ─────
RUNPOD_API_KEY=your_runpod_api_key_here
RUNPOD_ENDPOINT_ID=your_runpod_endpoint_id_here
